<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" id="metaThemeColor" content="#DA291C">
  <title>{{ profile.name }}</title>
  <meta name="description" content="{{ profile.tagline }}">
  <meta name="author" content="{{ profile.name }}">
  <meta name="generator" content="Monolog">

  <!-- Canonical -->
  <link rel="canonical" href="{{ profile.url }}">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ profile.name }}">
  <meta property="og:description" content="{{ profile.tagline }}">
  <meta property="og:url" content="{{ profile.url }}">
  <meta property="og:site_name" content="{{ profile.name }}">
  {% if profile.og_image %}<meta property="og:image" content="{{ profile.og_image }}">{% endif %}

  <!-- The Look -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=IBM+Plex+Serif:ital@0;1&family=IBM+Plex+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;700&family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;700&family=Fraunces:opsz,wght@9..144,400;9..144,700&family=Outfit:wght@400;700&family=Anton&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="sanko.css">

  <!-- Feeds -->
  {% for feed in feeds %}<link rel="alternate" type="{{ feed.mime }}" title="{{ feed.title }}" href="{{ feed.file }}" />
  {% endfor %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=IBM+Plex+Serif:ital@0;1&family=IBM+Plex+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;700&family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;700&family=Fraunces:opsz,wght,9..144,400;9..144,700&family=Outfit:wght@400;700&family=Anton&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="sanko.css">

  {% if analytics.plausible.enabled %}<!-- Plausible analytics -->
  <script defer data-domain="{{ analytics.plausible.domain }}" src="{{ analytics.plausible.src }}"></script>
  {% endif %}
  {% if analytics.cloudflare.enabled %}<!-- Cloudflare analytics -->
  <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "{{ analytics.cloudflare.token }}"}'></script>
  {% endif %}

  <!-- -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "mainEntity": {
      "@type": "Person",
      "name": "{{ profile.name }}",
      "url": "{{ profile.url }}"
    }
  }
  </script>

  <!-- ANTI-FOUC SCRIPT: Applies theme before the browser paints the first frame -->
  <script>
    (function() {
      // 1. Fetch color or use the default Swiss Red
      var c = localStorage.getItem('swiss-color') || '#DA291C';
      document.documentElement.style.setProperty('--primary', c);

      // 2. FORCE the HTML canvas to paint instantly, killing the View Transition white flash
      document.documentElement.style.backgroundColor = c;

      var m = document.getElementById('metaThemeColor');
      if (m) m.setAttribute('content', c);

      // 3. Fetch and inject fonts
      var f = localStorage.getItem('swiss-font');
      if (f) {
        document.documentElement.style.setProperty('--font', f);
        var fontName = f.split(',')[0].replace(/['"]/g, '').trim();
        var l = document.createElement('link');
        l.rel = 'stylesheet';
        l.href = 'https://fonts.googleapis.com/css2?family=' + fontName.replace(/ /g,'+') + ':wght@400;700;900&display=swap';
        document.head.appendChild(l);
      }
    })();
  </script>
</head>
<body class="swiss-page">

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <form class="filter-wrap" id="mainForm">
    <!-- HIDDEN CHECKBOXES -->
    <input type="checkbox" id="tag-compilers" class="filter-cb" value="compilers">
    <input type="checkbox" id="tag-runtimes" class="filter-cb" value="runtimes">
    <input type="checkbox" id="tag-network" class="filter-cb" value="network">
    <input type="checkbox" id="tag-parsers" class="filter-cb" value="parsers">
    <input type="checkbox" id="tag-codegen" class="filter-cb" value="codegen">
    <input type="checkbox" id="tag-jit" class="filter-cb" value="jit">

    <!-- VIEW TOGGLES -->
    <input type="radio" name="view" id="view-projects" value="projects" class="view-cb" checked>
    <input type="radio" name="view" id="view-articles" value="articles" class="view-cb">

    <nav class="swiss-nav">
      <a href="index.html" class="nav-mark" aria-label="Home">SR</a>
      <button type="button" class="nav-settings" id="settingsToggle" aria-expanded="false" aria-controls="settingsPanel" aria-label="Toggle display settings">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
      </button>
    </nav>

    <div class="settings-panel" id="settingsPanel" hidden>
      <div class="settings-group">
        <label class="settings-label" for="fontSelect">Typeface</label>
        <select class="settings-select" id="fontSelect"></select>
      </div>
      <div class="settings-group">
        <label class="settings-label">Accent Color</label>
        <div class="color-presets" aria-label="Color presets">
          <button type="button" class="preset-btn" data-color="#DA291C" style="--swatch: #DA291C" aria-label="Swiss Red"></button>
          <button type="button" class="preset-btn" data-color="#D4FF00" style="--swatch: #D4FF00" aria-label="Chartreuse"></button>
          <button type="button" class="preset-btn" data-color="#FF1493" style="--swatch: #FF1493" aria-label="Deep Pink"></button>
          <button type="button" class="preset-btn" data-color="#0055FF" style="--swatch: #0055FF" aria-label="Cobalt Blue"></button>
          <button type="button" class="preset-btn" data-color="#FF5E00" style="--swatch: #FF5E00" aria-label="Safety Orange"></button>
          <button type="button" class="preset-btn" data-color="#8A2BE2" style="--swatch: #8A2BE2" aria-label="Electric Purple"></button>
          <button type="button" class="preset-btn" data-color="#00E5FF" style="--swatch: #00E5FF" aria-label="Cyan"></button>
          <button type="button" class="preset-btn" data-color="#111111" style="--swatch: #111111" aria-label="Pitch Black"></button>
        </div>
        <div class="color-row">
          <label for="colorPicker" class="sr-only" style="display:none;">Custom color picker</label>
          <input type="color" class="settings-color" id="colorPicker" value="#da291c">
          <span class="color-hex" id="colorHex" aria-hidden="true">#DA291C</span>
        </div>
      </div>
      <div class="settings-group settings-close-row">
        <small class="settings-hint">Click <kbd>ESC</kbd> or tap outside to close</small>
      </div>
    </div>

    <main id="main-content">
      <section class="swiss-hero">
        <h1 class="hero-name">Sanko<br>Robinson</h1>
        <p class="hero-bio">
          I design and implement <label for="tag-compilers" class="filter-label" tabindex="0">compilers</label>, <label for="tag-runtimes" class="filter-label" tabindex="0">runtimes</label>, and the infrastructure that powers them. I also maintain several <label for="tag-network" class="filter-label" tabindex="0">network protocols</label> and systems utilities.
        </p>
        <p class="hero-bio">
          My work spans the full stack: from lexers and <label for="tag-parsers" class="filter-label" tabindex="0">parsers</label> in the frontend, through intermediate representations, to register allocation and <label for="tag-codegen" class="filter-label" tabindex="0">code generation</label>.
        </p>
        <p class="hero-bio">
          Currently focused on <label for="tag-jit" class="filter-label" tabindex="0">trace-based JIT compilation</label> and verified code generation.
        </p>

        <div class="view-toggles">
          <div class="view-tabs">
            <label for="view-projects" class="view-label" tabindex="0">Projects</label>
            <label for="view-articles" class="view-label" tabindex="0">Writing</label>
          </div>
          <button id="clearFiltersBtn" class="clear-btn" aria-label="Clear all active filters">Clear filters ✕</button>
        </div>
      </section>

      <!-- VIEW 1: PROJECTS -->
      <div class="proj-list">

              {% for project in projects %}
        <div class="proj-row" data-tags="{{ project.tags | join: ' ' }}">
          <a href="#" class="proj-link-wrap" aria-label="Project: {{ project.name }}">
            <div class="proj-stack">
              <span class="proj-name">{{ project.name }}</span>
              <span class="proj-desc">{{ project.blurb }}</span>
            </div>
          </a>
          {% if project.articles.size > 0 %}
          <div class="proj-articles">
            <div class="proj-articles-list">
              {% for article in project.articles %}
              <article class="proj-article">
                <span class="entry-meta">{{ article.date | date: "%Y·%m·%d" }}</span>
                <div class="entry-body">
                  <h3><a href="/articles/{{ article.slug }}/">{{ article.title }}</a></h3>
                  <!--<p>{{ article.excerpt }}</p>-->
                </div>
              </article>
              {% endfor %}
            </div>
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </div>

      <!-- VIEW 2: ARTICLES ARCHIVE -->
      <div class="archive-wrap">
      {% for year_group in article_timeline %}
        <div class="year-group">
          <h2 class="year-label">{{ year_group.year }}</h2>
          {% for article in year_group.articles %}
          <article class="article-row" data-tags="{{ article.tags | join: ' ' }}">
            <a href="/articles/{{ article.slug }}/" class="article-link-wrap">
              <div class="article-meta"><time datetime="{{ article.date | date: "%Y-%m-%d" }}">{{ article.date | date: "%b %d" }}</time></div>
              <div class="article-content">
                <h3 class="article-title">{{ article.title }}</h3>
                <p class="article-desc">{{ article.excerpt }}</p>
              </div>
            </a>
          </article>
          {% endfor %}
        </div>
        {% endfor %}

        <div class="year-group">
          <h2 class="year-label">2026</h2>
          <article class="article-row" data-tags="compilers jit">
            <a href="article.html" class="article-link-wrap">
              <div class="article-meta"><time datetime="2026-06-14">JUN 14</time></div>
              <div class="article-content">
                <h3 class="article-title">A Tour of SSA Form Construction</h3>
                <p class="article-desc">How static single assignment form simplifies and enables modern compiler optimizations.</p>
              </div>
            </a>
          </article>
          <article class="article-row" data-tags="compilers parsers">
            <a href="article.html" class="article-link-wrap">
              <div class="article-meta"><time datetime="2026-05-02">MAY 02</time></div>
              <div class="article-content">
                <h3 class="article-title">Intermediate Representations</h3>
                <p class="article-desc">On the design space of IRs: from abstract syntax trees to control flow graphs to sea-of-nodes architectures.</p>
              </div>
            </a>
          </article>
          <article class="article-row" data-tags="runtimes codegen jit">
            <a href="article.html" class="article-link-wrap">
              <div class="article-meta"><time datetime="2026-04-18">APR 18</time></div>
              <div class="article-content">
                <h3 class="article-title">Building a Register Allocator</h3>
                <p class="article-desc">A practical walkthrough of graph coloring and linear scan approaches for JIT compilation.</p>
              </div>
            </a>
          </article>
        </div>

        <div class="year-group">
          <h2 class="year-label">2025</h2>
          <article class="article-row" data-tags="compilers parsers">
            <a href="article.html" class="article-link-wrap">
              <div class="article-meta"><time datetime="2025-12-04">DEC 04</time></div>
              <div class="article-content">
                <h3 class="article-title">A Minimal C Frontend in 500 Lines</h3>
                <p class="article-desc">Building a lexer, recursive descent parser, and AST generator from scratch.</p>
              </div>
            </a>
          </article>
        </div>
      </div>
    </main>
  </form>

  <script src="sanko.js"></script>
</body>
</html>

